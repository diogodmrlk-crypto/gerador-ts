{
  "buildCommand": "echo 'Static site'",
  "outputDirectory": "public",
  "framework": null,
  "rewrites": [
    {
      "source": "/",
      "destination": "/app/index.html"
    },
    {
      "source": "/home",
      "destination": "/app/index.html"
    },
    {
      "source": "/keys",
      "destination": "/app/index.html"
    },
    {
      "source": "/devices",
      "destination": "/app/index.html"
    },
    {
      "source": "/packages",
      "destination": "/app/index.html"
    },
    {
      "source": "/profile",
      "destination": "/app/index.html"
    },
    {
      "source": "/app",
      "destination": "/app/index.html"
    },
    {
      "source": "/app/:path*",
      "destination": "/app/index.html"
    }
  ],
  "headers": [
    {
      "source": "/app/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000"
        }
      ]
    }
  ]
}
